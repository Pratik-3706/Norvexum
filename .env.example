# ═══════════════════════════════════════════════════════════════════════════
# Norvexum — Environment Configuration
# Copy to .env and fill in your keys
# ═══════════════════════════════════════════════════════════════════════════

# ── AI Providers ──────────────────────────────────────────────────────────
# aicredits.in gateway (OpenAI-compatible, INR billing, 300+ models)
AICREDITS_API_KEY=

# Google AI Studio (FREE tier — no billing required)
GOOGLE_AI_API_KEY=

# OpenAI direct
OPENAI_API_KEY=

# Anthropic direct
ANTHROPIC_API_KEY=

# ── Web Search ────────────────────────────────────────────────────────────
# Tavily (primary) — https://app.tavily.com
TAVILY_API_KEY=

# ── OCR (fallback when model lacks vision) ────────────────────────────────
# OCR.space — https://ocr.space/ocrapi (25K free requests/month)
OCR_SPACE_API_KEY=

# ── Image Generation ──────────────────────────────────────────────────────
# Pollinations (Flux) — free, no key needed for basic usage
POLLINATIONS_API_KEY=
